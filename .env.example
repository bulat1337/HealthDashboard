HEALTH_DATA_DIR="./data/xiaomi-body-scale"
MONEY_DATA_FILE="./data/money/Money.md"
HEALTH_DEFAULT_TIMEZONE="UTC"
PORT=5000
HOST=127.0.0.1

# Optional ZenMoney money sync. Put real tokens and secrets in .env.local or
# ~/.codex/state/health-dashboard-money-sync/zenmoney-token.json.
# ZENMONEY_TOKEN_FILE="$HOME/.codex/state/health-dashboard-money-sync/zenmoney-token.json"
# ZENMONEY_CLIENT_ID="replace-with-oauth-client-id"
# ZENMONEY_CLIENT_SECRET="replace-with-oauth-client-secret"
# ZENMONEY_REDIRECT_URI="http://127.0.0.1:53682/callback"
# MONEY_SYNC_ENABLED="true"
# MONEY_SYNC_TIMEZONE="Europe/Moscow"
# MONEY_SYNC_START_HOUR=8
# MONEY_SYNC_END_HOUR=23
# MONEY_SYNC_FINAL_MINUTE=30
# Optional ZenMoney-only mobile trigger. Configure either a webhook URL from
# an Android automation app or a local command that starts ZenMoney sync on the phone.
# ZENMONEY_PRE_SYNC_URL="http://phone-or-automation-host/sync-zenmoney"
# ZENMONEY_PRE_SYNC_TOKEN="replace-with-a-long-random-token"
# ZENMONEY_PRE_SYNC_COMMAND=""
# ZENMONEY_PRE_SYNC_WAIT_MS=45000

# Set this only on machines that accept POST /api/health-data/measurements.
# HEALTH_INGEST_TOKEN="replace-with-a-long-random-token"
# Optional fallback when BLE payloads do not include a Xiaomi profile id.
# HEALTH_INGEST_DEFAULT_USER="Demo User"

# Optional local-only relationship settings. Put real values in .env.local.
VITE_RELATIONSHIP_TITLE="Relationship"
VITE_RELATIONSHIP_START="2024-01-01"
VITE_RELATIONSHIP_PHOTO_DATE="2024-05-20"
VITE_RELATIONSHIP_PHOTO_CAPTION="Demo milestone"
# Optional remote or public asset URL. Leave empty to use the bundled demo image.
VITE_RELATIONSHIP_PHOTO_URL=""
